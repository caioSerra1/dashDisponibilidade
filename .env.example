# --- App ---
NODE_ENV=production
# URL pública por onde o app é acessado.
# - Local: http://localhost:3000
# - Produção (EasyPanel): https://indicadores.portaledtech.com
NEXTAUTH_URL=https://indicadores.portaledtech.com
NEXTAUTH_SECRET=change-me-min-32-chars-rotate-in-prod
CRON_SECRET=change-me-min-32-chars-rotate-in-prod

# --- Database ---
# Em produção (EasyPanel), use a URL INTERNA (dados_postgres:5432).
# Sempre usar ?schema=dash_variavel para isolar do schema public.
DATABASE_URL=postgresql://postgres:SENHA@dados_postgres:5432/dados?sslmode=disable&schema=dash_variavel

# --- ClickUp ---
CLICKUP_API_TOKEN=pk_xxx
CLICKUP_TEAM_ID=90132606974

# --- Zabbix (self-hosted) ---
# Senhas com '#' precisam ficar entre aspas duplas no .env.
ZABBIX_URL=https://monitoramento.cursosdoportal.com.br/api_jsonrpc.php
ZABBIX_USER=admin
ZABBIX_PASSWORD="senha-aqui"

# --- Seed (dev only) ---
SEED_ADMIN_EMAIL=tecnologia@cursosdoportal.com.br
SEED_ADMIN_PASSWORD=trocar-no-primeiro-login
